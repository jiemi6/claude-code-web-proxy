# claude-code-web-proxy - Environment Variables
# Copy to .env and adjust as needed. All variables are optional.

# Bind address for the HTTP/WebSocket server.
# Leave empty to auto-detect the machine's LAN IPv4 address (LAN-only access).
# Set to 127.0.0.1 for localhost-only, or an explicit IP for a specific interface.
# WARNING: setting to 0.0.0.0 exposes the service on ALL interfaces (including public).
HOST=

# Listen port.
PORT=8199

# Path to the Claude Code CLI binary. Auto-detected from PATH if unset.
# CLAUDE_BIN=/home/youruser/.local/bin/claude
